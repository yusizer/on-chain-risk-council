# ── Qwen Cloud (DashScope, OpenAI-compatible) ───────────────────────────────
# Get at https://dashscope-intl.aliyuncs.com/ (hackathon coupon: see Resources)
DASHSCOPE_API_KEY=sk-replace-me
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Helius (Solana RPC + MCP server) ────────────────────────────────────────
# Get at https://www.helius.dev/ (free tier ok)
HELIUS_API_KEY=replace-me
# Solana network: mainnet (read-only) | devnet
SOLANA_NETWORK=mainnet

# ── Alibaba Cloud RDS PostgreSQL + pgvector ─────────────────────────────────
# ApsaraDB RDS for PostgreSQL, pgvector extension enabled
DATABASE_URL=postgresql://USER:PASS@pgm-XXXX.pg.rds.aliyuncs.com:5432/riskcouncil
PGSSLMODE=require

# ── Alibaba Cloud deployment proof (used by alibaba/proof.ts) ───────────────
# ECS instance running the Next.js backend + RDS pgvector
ALIYUN_ACCESS_KEY_ID=replace-me
ALIYUN_ACCESS_KEY_SECRET=replace-me
ALIYUN_REGION=ap-southeast-1
ALIYUN_ECS_INSTANCE_ID=replace-me
ALIYUN_RDS_INSTANCE_ID=replace-me

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
