# ── Qwen Cloud (DashScope, OpenAI-compatible) ───────────────────────────────
# Get at https://dashscope-intl.aliyuncs.com/ (hackathon coupon: see Resources)
DASHSCOPE_API_KEY=sk-replace-me
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Helius (Solana RPC + MCP server) ────────────────────────────────────────
# Get at https://www.helius.dev/ (free tier ok)
HELIUS_API_KEY=replace-me
# Solana network: mainnet only. Devnet is rejected until Helius MCP cluster routing is wired.
SOLANA_NETWORK=mainnet

# ── PostgreSQL + pgvector ───────────────────────────────────────────────────
# Single-ECS free-trial deploy uses the pgvector container in docker-compose.yml.
# Pick any strong random password; docker-compose injects DATABASE_URL for app.
POSTGRES_PASSWORD=replace-with-strong-random-password
DATABASE_URL=postgresql://riskcouncil:replace-with-strong-random-password@localhost:5432/riskcouncil
PGSSLMODE=disable

# ── Alibaba Cloud deployment proof (used by alibaba/proof.ts) ───────────────
# ECS instance running the Next.js backend + local pgvector container
ALIYUN_REGION=ap-southeast-1
ALIYUN_ECS_INSTANCE_ID=replace-me
# Optional if you later add managed RDS; not required for single-ECS proof.
ALIYUN_RDS_INSTANCE_ID=

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
QWEN_TIMEOUT_MS=60000
COUNCIL_MAX_ACTIVE=3
COUNCIL_MAX_PER_WINDOW=20
COUNCIL_WINDOW_MS=600000
# Optional: if set, POST /api/actions and /api/stream require Bearer or x-council-token.
COUNCIL_API_TOKEN=
# Only set false for self-signed/internal Postgres certificates.
PGSSL_REJECT_UNAUTHORIZED=true
